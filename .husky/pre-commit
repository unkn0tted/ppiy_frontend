#!/bin/sh

set -e

npm test

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to format"
  exit 0
fi

STASH_NAME="pre-commit-$(date +%s)"
HAS_STASH=0

if ! git diff --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  git stash push --quiet --keep-index --include-untracked --message "$STASH_NAME"
  HAS_STASH=1
fi

echo "$STAGED_FILES" | xargs bun x ultracite fix

echo "$STAGED_FILES" | while IFS= read -r file; do
  if [ -f "$file" ]; then
    git add "$file"
  fi
done

if [ "$HAS_STASH" -eq 1 ]; then
  STASH_REF=$(git stash list | grep "$STASH_NAME" | head -n 1 | cut -d: -f1)
  if [ -n "$STASH_REF" ]; then
    git stash pop --quiet "$STASH_REF" || true
  fi
fi
